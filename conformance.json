{
  "name": "rat-py",
  "version": "0.5.0",
  "protocol": "mrp",
  "protocolVersion": "0.4.0-draft",
  "transport": ["stdio", "http"],
  "features": {
    "execute": true,
    "stream": true,
    "variables": true,
    "inspect": true,
    "complete": true,
    "input": true,
    "reset": true,
    "cancel": true
  },
  "command": [
    "rat_py",
    "--http"
  ]
}
